# Copy to .env at the repo root: cp .env.example .env
# One file for the whole repo. `npm run dev:api` reads it in apps/api/src/dev.ts.
# Next only reads .env files sitting next to apps/web, so `npm run dev:web` exports
# GOOGLE_GENERATIVE_AI_API_KEY out of this file by hand. Nothing else crosses over —
# PORT below is the API's, and Next would bind to it.

# Optional. Get one free at https://aistudio.google.com/apikey
# Without it the app still runs: heuristic column matching, /health says "degraded".
# In production, set it in the Vercel dashboard on BOTH projects — the web app makes
# the mapping call inside a server action until Phase 3 moves it to the API. Never
# prefix it with NEXT_PUBLIC_; that is what would ship it to the browser.
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Everything below has working local defaults; set only to override. ──

# API port (default 3001)
#PORT=3001

# Comma-separated origins the API accepts cross-origin requests from
# (default http://localhost:3000). In production: the web deployment's URL,
# set in the Vercel dashboard on the API project.
#WEB_ORIGIN=http://localhost:3000

# Where the web app finds the API (default http://localhost:3001). Local dev
# never needs this. In production it is set in the Vercel dashboard on the WEB
# project — Vercel builds from apps/web and never sees this file.
#NEXT_PUBLIC_API_URL=http://localhost:3001
