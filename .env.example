# Copy to .env at the repo root: cp .env.example .env
# One file for the whole repo, read by `npm run dev:api` in apps/api/src/dev.ts.
# Nothing here crosses into apps/web — the browser talks to the API over HTTP, and
# PORT below is the API's, which Next would otherwise bind to.

# Optional. Get one free at https://aistudio.google.com/apikey
# Without it the app still runs: heuristic column matching, /health says "degraded".
# In production, set it on the Vercel API project ONLY. The mapping call lives in the
# API. Never prefix it with NEXT_PUBLIC_; that is what would ship it to the browser.
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Everything below has working local defaults; set only to override. ──

# API port (default 3001)
#PORT=3001

# Comma-separated origins the API accepts cross-origin requests from
# (default http://localhost:3000). In production: the web deployment's URL, set in
# the Vercel dashboard on the API project. The browser posts the CSV straight to the
# API, so a wrong value here fails every import.
#WEB_ORIGIN=http://localhost:3000

# Where the browser finds the API (default http://localhost:3001). Local dev never
# needs this. In production it is set in the Vercel dashboard on the WEB project —
# Vercel builds from apps/web and never sees this file.
#NEXT_PUBLIC_API_URL=http://localhost:3001
