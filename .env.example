# Copy to .env at the repo root: cp .env.example .env
# Read by the API dev server (apps/api/src/dev.ts) and, later, the eval harness.

# Optional. Get one free at https://aistudio.google.com/apikey
# Without it the app still runs: heuristic column matching, /health says "degraded".
# In production this is set in the Vercel dashboard on the API project — never on
# the web project: the key must not reach the browser.
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Everything below has working local defaults; set only to override. ──

# API port (default 3001)
#PORT=3001

# Comma-separated origins the API accepts cross-origin requests from
# (default http://localhost:3000). In production: the web deployment's URL,
# set in the Vercel dashboard on the API project.
#WEB_ORIGIN=http://localhost:3000

# Where the web app finds the API (default http://localhost:3001). Local dev
# never needs this. In production it is set in the Vercel dashboard on the WEB
# project — Next.js does not read this root .env file.
#NEXT_PUBLIC_API_URL=http://localhost:3001
