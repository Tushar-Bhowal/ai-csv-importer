# Optional. Get one free at https://aistudio.google.com/apikey
# Without it the app still runs: it falls back to heuristic column matching and says so.
GOOGLE_GENERATIVE_AI_API_KEY=

# Where the web app finds the API. Local default below; in production this is the
# deployed API origin.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Comma-separated origins the API accepts cross-origin requests from.
WEB_ORIGIN=http://localhost:3000

PORT=3001
