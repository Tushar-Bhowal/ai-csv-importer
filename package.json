{
  "name": "ai-csv-importer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2"
  },
  "scripts": {
    "prepare": "npm run build -w @groweasy/core",
    "dev": "npm run build -w @groweasy/core && concurrently -k \"npm:dev:*\"",
    "dev:core": "npm run dev -w @groweasy/core",
    "dev:api": "npm run dev -w @groweasy/api",
    "dev:web": "npm run dev -w @groweasy/web",
    "build": "npm run build -w @groweasy/core && npm run build -w @groweasy/web",
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p eval/tsconfig.json",
    "test": "vitest run",
    "eval": "npm run build -w @groweasy/core && tsx eval/run.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
